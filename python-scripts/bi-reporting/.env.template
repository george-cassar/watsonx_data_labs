# watsonx.data Connection Configuration
# Copy this file to .env and update with your actual values

# Presto Connection Details
PRESTO_HOST=your-watsonx-data-hostname.com
PRESTO_PORT=8443
PRESTO_USER=your-username
PRESTO_PASSWORD=your-password

# Catalog and Schema
PRESTO_CATALOG=lab_catalog01
PRESTO_SCHEMA=analytics

# Security
PRESTO_USE_SSL=true

# Instructions:
# 1. Copy this file: cp .env.template .env
# 2. Update PRESTO_HOST with your watsonx.data hostname
# 3. Update PRESTO_USER with your username
# 4. Update PRESTO_PASSWORD with your password (leave empty if not required)
# 5. Adjust PRESTO_CATALOG and PRESTO_SCHEMA if different
# 6. Never commit .env to version control!